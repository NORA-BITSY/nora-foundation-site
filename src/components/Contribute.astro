---
// TODO(pat): replace these placeholders before launch.
const sponsorUrl     = "https://github.com/sponsors/NORA-BITSY";
const openCollective = "https://opencollective.com/nora-foundation";       // TODO: create account
const stripeLink     = "https://buy.stripe.com/TODO";                      // TODO: create payment link
const btcAddress     = "bc1qTODO_REPLACE_WITH_REAL_ADDRESS";               // TODO: real address
const ethAddress     = "0xTODO_REPLACE_WITH_REAL_ADDRESS";                 // TODO: real address
---
<section id="contribute" class="bg-ink-50 border-y border-ink-200">
  <div class="mx-auto max-w-6xl px-6 py-24">
    <div class="section-label mb-4">§5 — Get involved</div>
    <h2 class="font-serif text-4xl md:text-5xl leading-tight">
      Fund. Build. Adopt.
    </h2>
    <p class="mt-6 max-w-2xl text-lg text-ink-600 leading-relaxed">
      Canon is a public specification under CC0. Meridian-Canon is the first implementation and is under active construction. Both need support — financial, technical, adversarial review.
    </p>

    <div class="mt-14 grid md:grid-cols-3 gap-px bg-ink-200 border border-ink-200">

      <!-- FUND -->
      <div class="bg-white p-8">
        <div class="font-mono text-xs text-cardinal-600 uppercase tracking-wider mb-4">Fund</div>
        <h3 class="font-serif text-xl text-ink-800 mb-4">Sponsor the work.</h3>
        <p class="text-sm text-ink-600 mb-6 leading-relaxed">
          Funding pays for specification drafting, reference implementations, adversarial review, and published verifiers across languages.
        </p>

        <div class="space-y-3">
          <a class="btn w-full justify-between" href={sponsorUrl} target="_blank" rel="noopener">
            <span>GitHub Sponsors</span>
            <span class="font-mono text-xs text-ink-400">recurring</span>
          </a>
          <a class="btn w-full justify-between" href={openCollective} target="_blank" rel="noopener">
            <span>Open Collective</span>
            <span class="font-mono text-xs text-ink-400">transparent</span>
          </a>
          <a class="btn w-full justify-between" href={stripeLink} target="_blank" rel="noopener">
            <span>Card / ACH</span>
            <span class="font-mono text-xs text-ink-400">Stripe</span>
          </a>
        </div>

        <div class="mt-6 pt-6 border-t border-ink-200">
          <div class="font-mono text-xs text-ink-500 uppercase tracking-wider mb-3">Crypto</div>
          <div class="space-y-3 text-xs">
            <div>
              <div class="font-mono text-ink-500 mb-1">BTC</div>
              <code class="block p-2 bg-ink-50 border border-ink-200 text-ink-700 break-all select-all">{btcAddress}</code>
            </div>
            <div>
              <div class="font-mono text-ink-500 mb-1">ETH</div>
              <code class="block p-2 bg-ink-50 border border-ink-200 text-ink-700 break-all select-all">{ethAddress}</code>
            </div>
          </div>
        </div>
      </div>

      <!-- BUILD -->
      <div class="bg-white p-8">
        <div class="font-mono text-xs text-cardinal-600 uppercase tracking-wider mb-4">Build</div>
        <h3 class="font-serif text-xl text-ink-800 mb-4">Contribute code.</h3>
        <p class="text-sm text-ink-600 mb-6 leading-relaxed">
          Canon is implementation-neutral. You don't need permission from NORA to write a verifier, an issuer, or tooling against the spec.
        </p>

        <ul class="space-y-3 text-sm text-ink-700 mb-6">
          <li class="flex gap-2">
            <span class="text-cardinal-600 font-mono shrink-0">▸</span>
            <span>Write a verifier in your language (Rust, Go, TypeScript).</span>
          </li>
          <li class="flex gap-2">
            <span class="text-cardinal-600 font-mono shrink-0">▸</span>
            <span>Propose a new challenge type via PR.</span>
          </li>
          <li class="flex gap-2">
            <span class="text-cardinal-600 font-mono shrink-0">▸</span>
            <span>Review the draft spec before v1.0 lock.</span>
          </li>
          <li class="flex gap-2">
            <span class="text-cardinal-600 font-mono shrink-0">▸</span>
            <span>Port Meridian-Canon modules (Python backends).</span>
          </li>
        </ul>

        <a class="btn w-full justify-center" href="https://github.com/NORA-BITSY" target="_blank" rel="noopener">
          GitHub · NORA-BITSY
        </a>
      </div>

      <!-- ADOPT -->
      <div class="bg-white p-8">
        <div class="font-mono text-xs text-cardinal-600 uppercase tracking-wider mb-4">Adopt</div>
        <h3 class="font-serif text-xl text-ink-800 mb-4">Issue Attestations.</h3>
        <p class="text-sm text-ink-600 mb-6 leading-relaxed">
          Canon is for any system that issues reasoning claims recipients must verify without trusting the issuer — legal, regulatory, journalism, research, audit.
        </p>

        <ul class="space-y-3 text-sm text-ink-700 mb-6">
          <li class="flex gap-2">
            <span class="text-cardinal-600 font-mono shrink-0">▸</span>
            <span><strong>Legal</strong> — court-admissible AI-assisted discovery output.</span>
          </li>
          <li class="flex gap-2">
            <span class="text-cardinal-600 font-mono shrink-0">▸</span>
            <span><strong>Journalism</strong> — source-citable generative reporting.</span>
          </li>
          <li class="flex gap-2">
            <span class="text-cardinal-600 font-mono shrink-0">▸</span>
            <span><strong>Audit &amp; compliance</strong> — verifiable automated review.</span>
          </li>
          <li class="flex gap-2">
            <span class="text-cardinal-600 font-mono shrink-0">▸</span>
            <span><strong>Research</strong> — reproducible retrieval for private corpora.</span>
          </li>
        </ul>

        <a class="btn w-full justify-center" href="mailto:hello@norafoundation.io?subject=Adopting%20Canon">
          Contact us
        </a>
      </div>
    </div>

    <div class="mt-12 max-w-3xl text-sm text-ink-500 leading-relaxed">
      <strong class="text-ink-700">501(c)(3) status.</strong> The NORA Foundation is pursuing fiscal sponsorship. Donations are presently made to the project author; tax-deductible routing via fiscal host is in progress. For grants and institutional funding, please <a class="link-subtle" href="mailto:hello@norafoundation.io">reach out directly</a>.
    </div>
  </div>
</section>
