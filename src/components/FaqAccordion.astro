---
import { faqItems } from "../data/faq";
---
<div class="border-t border-ink-200">
  {faqItems.map(item => (
    <details class="group border-b border-ink-200 py-5">
      <summary class="flex items-start justify-between gap-4 cursor-pointer list-none text-ink-800 font-serif text-lg hover:text-cardinal-700 transition-colors">
        <span>{item.q}</span>
        <span class="font-mono text-cardinal-600 text-xl leading-none group-open:rotate-45 transition-transform mt-1">+</span>
      </summary>
      <div class="mt-4 text-ink-600 leading-relaxed max-w-3xl">{item.a}</div>
    </details>
  ))}
</div>
